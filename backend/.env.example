# Copy to backend/.env and fill in your own values.
# Never commit the real .env file.

# --- PostgreSQL (Supabase) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>.supabase.co:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# --- Redis (Upstash) ---
SPRING_DATA_REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# --- JWT (must be at least 256 bits / 32 chars) ---
JWT_SECRET=

# --- Cloudinary (medical reports + avatars) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Twilio WhatsApp Sandbox ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_SANDBOX_CODE=
TWILIO_WEBHOOK_VERIFY=false

# --- Gemini (Google Generative Language API, free tier) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Public base URL (ngrok in dev, Render URL in prod) ---
PUBLIC_BASE_URL=

# --- Server ---
PORT=8080
